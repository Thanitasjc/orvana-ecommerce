# Copy to deploy.env and fill in values (do NOT commit deploy.env)
# SUPABASE_ACCESS_TOKEN=   # from: npx supabase login
# SUPABASE_DB_PASSWORD=    # database password you choose when creating project
# SUPABASE_PROJECT_REF=    # project ref after create (e.g. abcdefghijklmnop)
# DATABASE_URL=            # postgresql://... from Supabase Dashboard
# RENDER_API_KEY=          # from Render Dashboard → Account Settings → API Keys
# VERCEL_TOKEN=            # from Vercel → Account Settings → Tokens
# RENDER_SERVICE_URL=      # e.g. https://aesthete-api.onrender.com
# VERCEL_APP_URL=          # e.g. https://orvana-ecommerce.vercel.app
